PORT=3001
TREASURY_WALLET=0xYourTreasuryWallet

# EVM RPC endpoints
ETH_RPC_URL=
ARB_RPC_URL=
BSC_RPC_URL=

# Optional USDT contract overrides
ETH_USDT=0xdAC17F958D2ee523a2206206994597C13D831ec7
ARB_USDT=0xFd086bC7CD5C481DCC9C85ebe478A1C0b69FCbb9
BSC_USDT=0x55d398326f99059fF775485246999027B3197955

# Admin auth
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
# Or set a bcrypt hash directly
# ADMIN_PASSWORD_HASH=

JWT_SECRET=change-this-secret
# Session (用于 X 登录)
SESSION_SECRET=change-this-session-secret

# X (Twitter) OAuth 2.0 登录（详见 docs/X-OAUTH-SETUP.md）
# 控制台 Callback 须与下面 BASE_URL 完全一致，例如：
#   http://localhost:3001/api/auth/twitter/callback
# App 类型选 Web App，以获取 Client Secret；权限需包含 tweet.read、users.read、offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
BASE_URL=http://localhost:3001

# 管理员 X 账号（不含 @），逗号分隔；登录后可绕过投票粉丝数限制，并用 Cookie 访问 /api/admin/* 与 admin.html
ADMIN_TWITTER_HANDLES=

# RapidAPI - Twitter 粉丝数同步（可选）
# 在 rapidapi.com 订阅 Twitter/X API 后填写
RAPIDAPI_KEY=
RAPIDAPI_TWITTER_HOST=twittr-v2-fastest-twitter-x-api-150k-requests-for-15.p.rapidapi.com
# 可选：twitter-social 等（与主 API 同一 RapidAPI Key 需分别订阅）
# - 粉丝列表：/api/v1/twitter/user/followers
# - 头像兜底：主 API 返回结构变化时，会用 /api/v1/twitter/user/profile?username=
# RAPIDAPI_FOLLOWERS_HOST=twitter-social.p.rapidapi.com
